# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Azure Static Web Apps
# The deployment token will be automatically configured in GitHub Secrets
# AZURE_STATIC_WEB_APPS_API_TOKEN=<configured-in-github-secrets>

# Azure AI Foundry Configuration
AZURE_OPENAI_ENDPOINT=your-foundry-endpoint
AZURE_OPENAI_API_KEY=your-foundry-api-key
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_API_VERSION=2024-11-20

# TMDB API (for movie metadata)
TMDB_API_KEY=your-tmdb-api-key

# Build Configuration
NODE_ENV=production
